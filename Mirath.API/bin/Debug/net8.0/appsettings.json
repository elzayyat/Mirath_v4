{
  "ConnectionStrings": {},
  "Jwt": {
    "Secret": "",
    "Issuer": "mirath-api",
    "Audience": "mirath-client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "Storage": {
    "Path": "/var/mirath/storage"
  },
  "RateLimiting": {
    "AuthAttemptsPerMinute": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
